# ClawWithTail Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ── LLM API Keys ──────────────────────────────────────────────────────────────
OPENAI_API_KEY=
# Custom base URL for OpenAI-compatible APIs (DeepSeek, Moonshot, local Ollama, etc.)
# Leave empty to use the official OpenAI endpoint (https://api.openai.com/v1)
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here

# ── Notification ──────────────────────────────────────────────────────────────
# Feishu (Lark) incoming webhook URL
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token-here

# ── Knowledge Tools ───────────────────────────────────────────────────────────
# Tavily API key for web search (https://tavily.com)
TAVILY_API_KEY=tvly-your-tavily-key-here
